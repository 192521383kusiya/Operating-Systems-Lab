#include <stdio.h>

#define MAX 5

int queue[MAX];
int front = -1, rear = -1;

// Insert process into ready queue
void enqueue(int process)
{
    if (rear == MAX - 1)
    {
        printf("Ready Queue is Full\n");
    }
    else
    {
        if (front == -1)
            front = 0;
        rear++;
        queue[rear] = process;
        printf("Process P%d added to Ready Queue\n", process);
    }
}

// Remove process from ready queue
void dequeue()
{
    if (front == -1 || front > rear)
    {
        printf("Ready Queue is Empty\n");
    }
    else
    {
        printf("Process P%d is Executed\n", queue[front]);
        front++;
    }
}

// Display ready queue
void display()
{
    int i;

    if (front == -1 || front > rear)
    {
        printf("Ready Queue is Empty\n");
    }
    else
    {
        printf("Ready Queue: ");
        for (i = front; i <= rear; i++)
        {
            printf("P%d ", queue[i]);
        }
        printf("\n");
    }
}

int main()
{
    enqueue(1);
    enqueue(2);
    enqueue(3);

    display();

    dequeue();

    display();

    enqueue(4);
    enqueue(5);

    display();

    return 0;
}
